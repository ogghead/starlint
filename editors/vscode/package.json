{
  "name": "starlint",
  "displayName": "starlint",
  "description": "Fast JS/TS linter with WASM plugin support",
  "version": "0.1.4",
  "publisher": "ogghead",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogghead/starlint",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/ogghead/starlint",
  "bugs": {
    "url": "https://github.com/ogghead/starlint/issues"
  },
  "keywords": [
    "linter",
    "javascript",
    "typescript",
    "lint",
    "static-analysis"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "starlint",
      "properties": {
        "starlint.path": {
          "type": "string",
          "default": "",
          "description": "Path to the starlint binary (auto-detected from PATH if empty)"
        },
        "starlint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the starlint linter"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "build": "tsc -p .",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "tsc -watch -p ."
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  }
}
