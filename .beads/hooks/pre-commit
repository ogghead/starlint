#!/usr/bin/env bash
# starlint pre-commit hook
#
# Runs the same checks as CI (format, clippy, machete, tests) to catch
# failures before they reach the remote. Skip with: git commit --no-verify
set -euo pipefail

echo "pre-commit: running checks..."

# ── Format check ─────────────────────────────────────────────────────────────
echo "  [1/4] cargo fmt --check"
if ! cargo fmt --all -- --check; then
    echo ""
    echo "ERROR: formatting check failed. Run 'cargo fmt --all' and retry." >&2
    exit 1
fi

# ── Clippy ───────────────────────────────────────────────────────────────────
echo "  [2/4] cargo clippy"
if ! cargo clippy --workspace --all-targets -- -D warnings; then
    echo ""
    echo "ERROR: clippy found warnings. Fix them and retry." >&2
    exit 1
fi

# ── Unused dependencies ─────────────────────────────────────────────────────
if command -v cargo-machete >/dev/null 2>&1; then
    echo "  [3/4] cargo machete"
    if ! cargo machete; then
        echo ""
        echo "ERROR: unused dependencies found. Remove them and retry." >&2
        exit 1
    fi
else
    echo "  [3/4] cargo machete (skipped — not installed)"
fi

# ── Tests ────────────────────────────────────────────────────────────────────
echo "  [4/4] cargo test"
if ! cargo test --workspace; then
    echo ""
    echo "ERROR: tests failed. Fix them and retry." >&2
    exit 1
fi

echo "pre-commit: all checks passed."

# ── Beads hook (issue tracking) ──────────────────────────────────────────────
if command -v bd >/dev/null 2>&1; then
    bd hooks run pre-commit "$@" || true
fi
